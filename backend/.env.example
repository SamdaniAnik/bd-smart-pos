# --- Required ---
DATABASE_URL="mysql://root:@localhost:3306/bd_pos"
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change_me_to_a_secure_random_value"

# --- Server ---
NODE_ENV=development
PORT=5001
TRUST_PROXY=loopback

# --- Logging ---
# Levels: trace | debug | info | warn | error | fatal
# Defaults: debug in development, info in production
LOG_LEVEL=

# --- Auth ---
JWT_EXPIRES_IN=24h

# --- CORS ---
# Comma-separated list. Leave empty in dev (open). REQUIRED in production
# (an empty list in prod denies all browser origins for safety).
# Example: ALLOWED_ORIGINS=https://pos.example.com,https://staging.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Rate limiting ---
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_BOOTSTRAP_WINDOW_MS=3600000
RATE_LIMIT_BOOTSTRAP_MAX=5

# --- Bootstrap (initial seed) ---
# Required in production. If unset in prod, /api/bootstrap/seed is disabled (503).
# Pass via header `X-Bootstrap-Token: <value>` or body `{ "seedToken": "<value>" }`.
BOOTSTRAP_SEED_TOKEN=

# --- Reports / receipt branding ---
REPORT_STORE_NAME="BD Smart POS"
REPORT_STORE_ADDRESS="Dhaka, Bangladesh"
REPORT_STORE_PHONE=""
REPORT_FOOTER_TEXT="Generated by BD Smart POS"
