model MfsPaymentSession {
  id                Int       @id @default(autoincrement())
  paymentId         String    @unique
  branchId          Int
  method            String
  provider          String
  amount            Float
  invoiceRef        String?
  status            String    @default("PENDING") // PENDING | VERIFIED | EXPIRED | REFUNDED
  merchantNumber    String?
  qrPayload         String?   @db.Text
  paymentUrl        String?   @db.Text
  providerPaymentId String?
  trxId             String?
  simulated         Boolean   @default(false)
  refundTrxId       String?
  refundedAmount    Float     @default(0)
  refundedAt        DateTime?
  refundReason      String?   @db.Text
  meta              Json?
  verifiedAt        DateTime?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, status])
  @@index([branchId, createdAt])
}

model LoyaltyOtpSession {
  id         Int      @id @default(autoincrement())
  branchId   Int
  customerId Int?
  cardToken  String?
  phone      String
  otpHash    String
  attempts   Int      @default(0)
  verified   Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([branchId, phone])
  @@index([expiresAt])
}

model SmsTemplate {
  id        Int      @id @default(autoincrement())
  branchId  Int
  key       String
  name      String?
  body      String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, key])
  @@index([branchId])
}

model SmsDeliveryLog {
  id                Int       @id @default(autoincrement())
  branchId          Int?
  customerId        Int?
  msisdn            String
  provider          String
  status            String    @default("PENDING") // PENDING | SENT | SIMULATED | DELIVERED | FAILED
  providerMessageId String?
  segments          Int       @default(1)
  encoding          String?
  purpose           String?
  errorMessage      String?   @db.Text
  dlrStatus         String?
  dlrAt             DateTime?
  createdAt         DateTime  @default(now())

  @@index([providerMessageId])
  @@index([branchId, createdAt])
}
