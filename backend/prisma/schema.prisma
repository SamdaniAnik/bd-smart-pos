  actor  User?  @relation(fields: [actorId], references: [id])

  @@index([chequeId])
}

model GiftCard {
  id         Int       @id @default(autoincrement())
  branchId   Int
  code       String    @unique
  balance    Float     @default(0)
  status     String    @default("ACTIVE")
  expiresAt  DateTime?
  customerId Int?
  createdAt  DateTime  @default(now())

  branch       Branch           @relation(fields: [branchId], references: [id])
  customer     Customer?        @relation(fields: [customerId], references: [id])
  transactions StoredValueTxn[]

  @@index([branchId])
}

model StoredValueTxn {
  id         Int      @id @default(autoincrement())
  giftCardId Int?
  customerId Int?
  saleId     Int?
  type       String
  amount     Float
  note       String?
  createdAt  DateTime @default(now())

  giftCard GiftCard? @relation(fields: [giftCardId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  sale     Sale?     @relation(fields: [saleId], references: [id])

  @@index([giftCardId])
  @@index([saleId])
}

// Mobile recharge (flexiload) and utility bill payment (DESCO/DPDC prepaid token,
// PDB, WASA, Titas gas, internet). These are commission-earning services, not
// stock items, so they live in their own ledger separate from Sale/SaleItem.
model UtilityTransaction {
  id               Int      @id @default(autoincrement())
  branchId         Int
  type             String // RECHARGE | BILL
  category         String // MOBILE | ELECTRICITY_PREPAID | ELECTRICITY_POSTPAID | GAS | WATER | INTERNET | OTHER
  operatorOrBiller String // GP, ROBI, DESCO, TITAS ...
  accountOrMsisdn  String // recharge number or meter/account number
  faceAmount       Float    @default(0)
  serviceCharge    Float    @default(0)
  commission       Float    @default(0)
  payMethod        String   @default("Cash") // Cash | MFS | Due
  payChannel       String? // bKash | Nagad | Rocket | Upay
  status           String   @default("SUCCESS") // SUCCESS | PENDING | FAILED
  providerRef      String?
  token            String? // prepaid electricity token
  customerId       Int?
  shiftId          Int?
  createdBy        Int?
  note             String?
  createdAt        DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId, createdAt])
  @@index([type, status])
}

model PromotionRule {
  id               Int       @id @default(autoincrement())
  branchId         Int
  name             String
  type             String
  productId        Int?
  category         String?
  buyQty           Int       @default(1)
  getQty           Int       @default(1)
  discountValue    Float     @default(0)
  bundlePrice      Float?
  bundleProductIds String?
  minBasketAmount  Float     @default(0)
  isActive         Boolean   @default(true)
  startsAt         DateTime?
  endsAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  branch           Branch    @relation(fields: [branchId], references: [id])
  product          Product?  @relation(fields: [productId], references: [id])

  @@index([branchId, isActive])
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  users           User[]
  rolePermissions RolePermission[]
}

model Permission {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  description     String?
  rolePermissions RolePermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model User {
  id                         Int                       @id @default(autoincrement())
  branchId                   Int
  roleId                     Int
  name                       String
  email                      String                    @unique
  passwordHash               String
  language                   String                    @default("en")
  isActive                   Boolean                   @default(true)
  createdAt                  DateTime                  @default(now())
  branch                     Branch                    @relation(fields: [branchId], references: [id])
  role                       Role                      @relation(fields: [roleId], references: [id])
  sales                      Sale[]
  shifts                     Shift[]
  drawerMovements            DrawerMovement[]
  journals                   Journal[]
  expenses                   Expense[]
  auditLogs                  AuditLog[]
  chequesCreated             Cheque[]                  @relation("ChequeCreator")
  chequeEvents               ChequeEvent[]
  pettyCashTxns              PettyCashTxn[]
  pettyCashClaimsCreated     PettyCashClaim[]          @relation("PettyCashClaimCreator")
  pettyCashClaimsReviewed    PettyCashClaim[]          @relation("PettyCashClaimReviewer")
  bankStatementAllocations   BankStatementAllocation[]
  closedBankImports          BankStatementImport[]     @relation("BankImportCloser")
  resolvedBankLineExceptions BankStatementLine[]       @relation("BankLineExceptionResolver")
}

model Shift {
