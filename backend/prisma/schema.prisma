model Supplier {
  id                Int              @id @default(autoincrement())
  branchId          Int
  name              String
  phone             String?
  address           String?
  payableBalance    Float            @default(0)
  tinNumber         String?
  binNumber         String?
  taxCategory       String?
  withholdingExempt Boolean          @default(false)
  withholdingNote   String?
  createdAt         DateTime         @default(now())
  branch            Branch           @relation(fields: [branchId], references: [id])
  purchases         Purchase[]
  payments          PaymentVoucher[]
  cheques           Cheque[]

  @@index([branchId, taxCategory])
}

model Purchase {
  id                 Int              @id @default(autoincrement())
  branchId           Int
  supplierId         Int
  invoiceNo          String?
  transportationCost Float            @default(0)
  bribesCost         Float            @default(0)
  extraOtherCost     Float            @default(0)
  total              Float
  paidAmount         Float            @default(0)
  dueAmount          Float            @default(0)
  /// SUPPLIER_CREDIT — unpaid amount increases supplier AP (2100). BANK_LOAN — unpaid amount posts to Bank Loans Payable (2320); supplier balance not increased for financed portion.
  financingSource    String           @default("SUPPLIER_CREDIT")
  loanReference      String?
  loanNote           String?
  loanMaturityDate   DateTime?
  createdAt          DateTime         @default(now())
  branch             Branch           @relation(fields: [branchId], references: [id])
  supplier           Supplier         @relation(fields: [supplierId], references: [id])
  items              PurchaseItem[]
  journals           Journal[]
  returns            PurchaseReturn[]

  @@unique([branchId, invoiceNo])
}

model PurchaseItem {
