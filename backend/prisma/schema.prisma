generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id            Int            @id @default(autoincrement())
  branchId      Int
  categoryId    Int?
  taxProfileId  Int?
  name          String
  price         Float
  stock         Int            @default(0)
  reorderLevel  Int            @default(0)
  category      String?
  sku           String?
  vatRate       Float          @default(0)
  defaultDiscountType  String?
  defaultDiscountValue Float    @default(0)
  batchTracked  Boolean        @default(false)
  sellByWeight  Boolean        @default(false)
  stockKg       Float          @default(0)
  hasVariants   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  saleItems     SaleItem[]
  variants      ProductVariant[]
  branch        Branch         @relation(fields: [branchId], references: [id])
  categoryRef   ProductCategory? @relation(fields: [categoryId], references: [id])
  taxProfile    TaxProfile?    @relation(fields: [taxProfileId], references: [id])
  purchaseItems PurchaseItem[]
  stockLedger   StockLedger[]
  stockTransferFrom StockTransferItem[] @relation("TransferFromProduct")
  stockTransferTo   StockTransferItem[] @relation("TransferToProduct")
  saleReturnItems SaleReturnItem[]
  promotionRules PromotionRule[]
  inventoryBatches InventoryBatch[]

  @@unique([branchId, sku])
}

model ProductVariant {
  id           Int       @id @default(autoincrement())
  branchId    Int
  productId    Int
  label       String    @default("")
  sku          String?
  barcode      String?
  stock        Int       @default(0)
  priceOverride Float?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  branch       Branch    @relation(fields: [branchId], references: [id])
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  saleItems    SaleItem[]

  @@unique([branchId, barcode])
  @@index([branchId, productId])
}

model Sale {
  id             Int          @id @default(autoincrement())
  branchId       Int
  cashierId      Int?
  invoiceNo      String?
  subTotal       Float        @default(0)
  vatAmount      Float        @default(0)
  discount       Float        @default(0)
  total          Float
  paidAmount     Float        @default(0)
  dueAmount      Float        @default(0)
  paymentMethod  String       @default("Cash")
  paymentChannel String?
  notes          String?
  customerId     Int?
  status         String       @default("completed")
  buyerBinOrNidNote   String?
  mushakDocumentNo    String?
  vatBreakdownSnapshot Json?
  couponCodeId   Int?
  couponDiscount Float        @default(0)
  createdAt      DateTime     @default(now())

  branch         Branch       @relation(fields: [branchId], references: [id])
  cashier        User?        @relation(fields: [cashierId], references: [id])
  customer       Customer?    @relation(fields: [customerId], references: [id])
  couponCode     CouponCode?  @relation(fields: [couponCodeId], references: [id])
  items          SaleItem[]
  journals       Journal[]
  returns        SaleReturn[]
  salePayments   SalePayment[]
  storedValueTxns StoredValueTxn[]

  @@unique([branchId, invoiceNo])
}

model SaleItem {
  id                Int             @id @default(autoincrement())
  saleId            Int
  productId        Int
  productVariantId  Int?
  qty               Float
  weightKg          Float?
  price             Float
  cost              Float           @default(0)
  sale              Sale            @relation(fields: [saleId], references: [id])
  product           Product         @relation(fields: [productId], references: [id])
  productVariant    ProductVariant? @relation(fields: [productVariantId], references: [id])
  batchAllocations SaleItemBatch[]
}

model Customer {
  id             Int         @id @default(autoincrement())
  branchId       Int
  name           String
  phone          String?
  address        String?
  birthDate      DateTime?
  marketingOptIn Boolean     @default(true)
  balance        Float       @default(0)
  creditLimit    Float       @default(0) // 0 = unlimited; >0 = max outstanding balance
  storedValueBalance Float   @default(0)
  createdAt      DateTime    @default(now())
  branch    Branch      @relation(fields: [branchId], references: [id])
  sales     Sale[]
  receipts  ReceiptVoucher[]
  giftCards GiftCard[]
  storedValueTxns StoredValueTxn[]
}

model Branch {
  id           Int              @id @default(autoincrement())
  code         String           @unique
  name         String
  address      String?
  phone        String?
  isActive     Boolean          @default(true)
  sellerBin         String?
  tradeLicenseNo    String?
  vatRegistrationLabel String?
  createdAt    DateTime         @default(now())
  users        User[]
  products     Product[]
  productVariants ProductVariant[]
  sales        Sale[]
  customers    Customer[]
  suppliers    Supplier[]
  purchases    Purchase[]
  warehouses   Warehouse[]
  registers    CashRegister[]
  journals     Journal[]
  expenses     Expense[]
  accounts     Account[]
  stockAdjustments StockAdjustment[]
  stockTransfersFrom StockTransfer[] @relation("TransferFromBranch")
  stockTransfersTo   StockTransfer[] @relation("TransferToBranch")
  taxProfiles   TaxProfile[]
  promotionRules PromotionRule[]
  inventoryBatches   InventoryBatch[]
  documentSequences  BranchDocumentSeq[]
  giftCards          GiftCard[]
  paymentSettlements PaymentSettlement[]
  couponCodes          CouponCode[]
  bankStatementImports BankStatementImport[]
  webhookSubscriptions WebhookSubscription[]
}

model CouponCode {
  id                Int       @id @default(autoincrement())
  branchId          Int
  code              String
  discountType      String    @default("PERCENT")
  discountValue     Float
  minBasketAmount   Float     @default(0)
  maxRedemptions    Int       @default(0)
  redemptionCount   Int       @default(0)
  isActive          Boolean   @default(true)
  startsAt          DateTime?
  endsAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  branch            Branch    @relation(fields: [branchId], references: [id])
  sales             Sale[]

  @@unique([branchId, code])
  @@index([branchId])
}

model BankStatementImport {
  id         Int                 @id @default(autoincrement())
  branchId   Int
  label      String?
  rowCount   Int                 @default(0)
  importedAt DateTime            @default(now())
  meta       Json?

  branch     Branch              @relation(fields: [branchId], references: [id])
  lines      BankStatementLine[]

  @@index([branchId])
}

model BankStatementLine {
  id                   Int                 @id @default(autoincrement())
  importId             Int
  txnDate              DateTime
  description          String?
  amount               Float
  direction            String              @default("CREDIT")
  reference            String?
  matchedSalePaymentId Int?                @unique
  matchedAt            DateTime?
  matchNote            String?

  import               BankStatementImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  matchedSalePayment   SalePayment?        @relation(fields: [matchedSalePaymentId], references: [id])
}

model WebhookSubscription {
  id        Int      @id @default(autoincrement())
  branchId  Int
  url       String   @db.Text
  secret    String   @default("")
  events    Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

model BranchDocumentSeq {
  id        Int    @id @default(autoincrement())
  branchId  Int
  scope     String
  periodKey String
  lastValue Int    @default(0)
  branch    Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, scope, periodKey])
}

model InventoryBatch {
  id             Int       @id @default(autoincrement())
  branchId       Int
  productId      Int
  batchCode      String
  expiryDate     DateTime?
  qtyOnHand      Int       @default(0)
  unitCost       Float     @default(0)
  legacyAuditLogId Int?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch         Branch    @relation(fields: [branchId], references: [id])
  product        Product   @relation(fields: [productId], references: [id])
  saleItemBatches SaleItemBatch[]

  @@unique([branchId, productId, batchCode])
  @@index([branchId, productId])
}

model SaleItemBatch {
  id         Int @id @default(autoincrement())
  saleItemId Int
  batchId    Int
  qty        Int

  saleItem   SaleItem        @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  batch      InventoryBatch  @relation(fields: [batchId], references: [id])

  @@index([saleItemId])
  @@index([batchId])
}

model SalePayment {
  id             Int       @id @default(autoincrement())
  saleId         Int
  method         String
  channel        String?
  amount         Float
  meta           Json?
  reconciledAt   DateTime?
  settlementId   Int?
  createdAt      DateTime  @default(now())

  sale             Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  settlement       PaymentSettlement? @relation(fields: [settlementId], references: [id])
  bankStatementLine BankStatementLine?

  @@index([saleId])
  @@index([method, reconciledAt])
  @@index([channel])
  @@index([settlementId])
}

model PaymentSettlement {
  id           Int      @id @default(autoincrement())
  branchId     Int
  provider     String
  periodStart  DateTime
  periodEnd    DateTime
  grossAmount  Float
  feeAmount    Float   @default(0)
  netAmount    Float
  externalRef  String?
  importedAt   DateTime @default(now())
  meta         Json?

  branch       Branch @relation(fields: [branchId], references: [id])
  payments     SalePayment[]
}

model GiftCard {
  id         Int      @id @default(autoincrement())
  branchId   Int
  code       String   @unique
  balance    Float    @default(0)
  status     String   @default("ACTIVE")
  expiresAt  DateTime?
  customerId Int?
  createdAt  DateTime @default(now())

  branch     Branch   @relation(fields: [branchId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])
  transactions StoredValueTxn[]

  @@index([branchId])
}

model StoredValueTxn {
  id          Int      @id @default(autoincrement())
  giftCardId  Int?
  customerId  Int?
  saleId      Int?
  type        String
  amount      Float
  note        String?
  createdAt   DateTime @default(now())

  giftCard    GiftCard? @relation(fields: [giftCardId], references: [id])
  customer    Customer? @relation(fields: [customerId], references: [id])
  sale        Sale?     @relation(fields: [saleId], references: [id])

  @@index([giftCardId])
  @@index([saleId])
}

model PromotionRule {
  id              Int       @id @default(autoincrement())
  branchId        Int
  name            String
  type            String
  productId       Int?
  category        String?
  buyQty          Int       @default(1)
  getQty          Int       @default(1)
  discountValue   Float     @default(0)
  bundlePrice     Float?
  bundleProductIds String?
  minBasketAmount Float     @default(0)
  isActive        Boolean   @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  branch          Branch    @relation(fields: [branchId], references: [id])
  product         Product?  @relation(fields: [productId], references: [id])

  @@index([branchId, isActive])
}

model Role {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  users        User[]
  rolePermissions RolePermission[]
}

model Permission {
  id            Int             @id @default(autoincrement())
  code          String          @unique
  description   String?
  rolePermissions RolePermission[]
}

model RolePermission {
  id           Int         @id @default(autoincrement())
  roleId       Int
  permissionId Int
  role         Role        @relation(fields: [roleId], references: [id])
  permission   Permission  @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model User {
  id            Int              @id @default(autoincrement())
  branchId      Int
  roleId        Int
  name          String
  email         String           @unique
  passwordHash  String
  language      String           @default("en")
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  branch        Branch           @relation(fields: [branchId], references: [id])
  role          Role             @relation(fields: [roleId], references: [id])
  sales         Sale[]
  shifts        Shift[]
  drawerMovements DrawerMovement[]
  journals      Journal[]
  expenses      Expense[]
  auditLogs     AuditLog[]
}

model Shift {
  id            Int         @id @default(autoincrement())
  branchId      Int
  userId        Int
  registerId    Int
  openedAt      DateTime    @default(now())
  closedAt      DateTime?
  openingCash   Float       @default(0)
  closingCash   Float?
  varianceReason String?
  user          User        @relation(fields: [userId], references: [id])
  register      CashRegister @relation(fields: [registerId], references: [id])
  drawerMovements DrawerMovement[]
}

model CashRegister {
  id            Int         @id @default(autoincrement())
  branchId      Int
  name          String
  branch        Branch      @relation(fields: [branchId], references: [id])
  shifts        Shift[]
}

model DrawerMovement {
  id        Int      @id @default(autoincrement())
  shiftId   Int
  branchId  Int
  userId    Int?
  type      String
  amount    Float
  reason    String
  createdAt DateTime @default(now())
  shift     Shift    @relation(fields: [shiftId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model Warehouse {
  id            Int           @id @default(autoincrement())
  branchId      Int
  name          String
  branch        Branch        @relation(fields: [branchId], references: [id])
  stockLedgers  StockLedger[]
}

model StockLedger {
  id            Int           @id @default(autoincrement())
  branchId      Int
  warehouseId   Int?
  productId     Int
  refType       String
  refId         Int?
  inQty         Int           @default(0)
  outQty        Int           @default(0)
  outWeightKg   Float?
  inWeightKg    Float?
  unitCost      Float         @default(0)
  createdAt     DateTime      @default(now())
  product       Product       @relation(fields: [productId], references: [id])
  warehouse     Warehouse?    @relation(fields: [warehouseId], references: [id])
}

model StockTransfer {
  id              Int                @id @default(autoincrement())
  fromBranchId    Int
  toBranchId      Int
  status          String             @default("draft")
  createdAt       DateTime           @default(now())
  fromBranch      Branch             @relation("TransferFromBranch", fields: [fromBranchId], references: [id])
  toBranch        Branch             @relation("TransferToBranch", fields: [toBranchId], references: [id])
  items           StockTransferItem[]
}

model StockTransferItem {
  id              Int       @id @default(autoincrement())
  transferId      Int
  fromProductId   Int
  toProductId     Int
  qty             Int
  transfer        StockTransfer @relation(fields: [transferId], references: [id])
  fromProduct     Product   @relation("TransferFromProduct", fields: [fromProductId], references: [id])
  toProduct       Product   @relation("TransferToProduct", fields: [toProductId], references: [id])
}

model StockAdjustment {
  id              Int        @id @default(autoincrement())
  branchId        Int
  productId       Int
  qtyChange       Int
  reason          String
  createdAt       DateTime   @default(now())
  branch          Branch     @relation(fields: [branchId], references: [id])
}

model Supplier {
  id              Int            @id @default(autoincrement())
  branchId        Int
  name            String
  phone           String?
  address         String?
  payableBalance  Float          @default(0)
  createdAt       DateTime       @default(now())
  branch          Branch         @relation(fields: [branchId], references: [id])
  purchases       Purchase[]
  payments        PaymentVoucher[]
}

model Purchase {
  id              Int            @id @default(autoincrement())
  branchId        Int
  supplierId      Int
  invoiceNo       String?
  total           Float
  paidAmount      Float          @default(0)
  dueAmount       Float          @default(0)
  createdAt       DateTime       @default(now())
  branch          Branch         @relation(fields: [branchId], references: [id])
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  items           PurchaseItem[]
  journals        Journal[]
  returns         PurchaseReturn[]

  @@unique([branchId, invoiceNo])
}

model PurchaseItem {
  id              Int       @id @default(autoincrement())
  purchaseId      Int
  productId       Int
  qty             Int
  cost            Float
  purchase        Purchase  @relation(fields: [purchaseId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])
}

model PurchaseReturn {
  id              Int       @id @default(autoincrement())
  purchaseId      Int
  amount          Float
  reason          String?
  createdAt       DateTime  @default(now())
  purchase        Purchase  @relation(fields: [purchaseId], references: [id])
}

model SaleReturn {
  id              Int              @id @default(autoincrement())
  saleId          Int
  amount          Float
  reason          String?
  createdAt       DateTime         @default(now())
  sale            Sale             @relation(fields: [saleId], references: [id])
  items           SaleReturnItem[]
}

model SaleReturnItem {
  id              Int         @id @default(autoincrement())
  saleReturnId    Int
  productId       Int
  qty             Int
  amount          Float
  saleReturn      SaleReturn  @relation(fields: [saleReturnId], references: [id])
  product         Product     @relation(fields: [productId], references: [id])
}

model ProductCategory {
  id              Int       @id @default(autoincrement())
  branchId        Int
  name            String
  products        Product[]
}

model TaxProfile {
  id              Int       @id @default(autoincrement())
  branchId        Int
  name            String
  rate            Float
  branch          Branch    @relation(fields: [branchId], references: [id])
  products        Product[]
}

model FiscalPeriod {
  id              Int       @id @default(autoincrement())
  branchId        Int
  name            String
  startDate       DateTime
  endDate         DateTime
  isClosed        Boolean   @default(false)
}

model Account {
  id              Int       @id @default(autoincrement())
  branchId        Int
  code            String
  name            String
  type            String
  isSystem        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  branch          Branch    @relation(fields: [branchId], references: [id])
  journalLines    JournalLine[]

  @@unique([branchId, code])
}

model Journal {
  id              Int       @id @default(autoincrement())
  branchId        Int
  saleId          Int?
  purchaseId      Int?
  createdBy       Int?
  refType         String
  refId           Int?
  narration       String?
  createdAt       DateTime  @default(now())
  branch          Branch    @relation(fields: [branchId], references: [id])
  sale            Sale?     @relation(fields: [saleId], references: [id])
  purchase        Purchase? @relation(fields: [purchaseId], references: [id])
  creator         User?     @relation(fields: [createdBy], references: [id])
  lines           JournalLine[]
}

model Expense {
  id            Int       @id @default(autoincrement())
  branchId      Int
  createdBy     Int?
  category      String
  description   String?
  amount        Float
  paymentMethod String    @default("Cash")
  expenseDate   DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  branch        Branch    @relation(fields: [branchId], references: [id])
  creator       User?     @relation(fields: [createdBy], references: [id])
}

model JournalLine {
  id              Int       @id @default(autoincrement())
  journalId       Int
  accountId       Int
  debit           Float     @default(0)
  credit          Float     @default(0)
  journal         Journal   @relation(fields: [journalId], references: [id])
  account         Account   @relation(fields: [accountId], references: [id])
}

model PaymentVoucher {
  id              Int       @id @default(autoincrement())
  branchId        Int
  supplierId      Int?
  amount          Float
  method          String
  note            String?
  createdAt       DateTime  @default(now())
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
}

model ReceiptVoucher {
  id              Int       @id @default(autoincrement())
  branchId        Int
  customerId      Int?
  amount          Float
  method          String
  note            String?
  createdAt       DateTime  @default(now())
  customer        Customer? @relation(fields: [customerId], references: [id])
}

model AuditLog {
  id              Int       @id @default(autoincrement())
  userId          Int?
  action          String
  entity          String
  entityId        Int?
  payload         Json?
  createdAt       DateTime  @default(now())
  user            User?     @relation(fields: [userId], references: [id])
}