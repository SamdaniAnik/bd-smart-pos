  purchaseId       Int
  productId        Int
  productVariantId Int?
  qty              Int
  cost             Float
  batchCode        String?
  expiryDate       DateTime?
  purchase         Purchase  @relation(fields: [purchaseId], references: [id])
  product          Product   @relation(fields: [productId], references: [id])
}

model PurchaseReturn {
