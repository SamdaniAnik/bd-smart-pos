model JournalLine {
  id        Int     @id @default(autoincrement())
  journalId Int
  accountId Int
  debit     Float   @default(0)
  credit    Float   @default(0)
  journal   Journal @relation(fields: [journalId], references: [id])
  account   Account @relation(fields: [accountId], references: [id])
}

model PaymentVoucher {
  id                 Int       @id @default(autoincrement())
  branchId           Int
  supplierId         Int?
  amount             Float
  method             String
  note               String?
  // Withholding tax (Bangladesh): seller's gross invoice = `amount`. Buyer
  // deducts `aitAmount` (Income Tax / Source Tax) and `vdsAmount` (VAT Deducted
  // at Source) on behalf of NBR; only `netPaid` actually leaves the buyer's
  // cash. Both retentions become liabilities owed to NBR (separate accounts).
  aitRate            Float     @default(0)
  aitAmount          Float     @default(0)
  vdsRate            Float     @default(0)
  vdsAmount          Float     @default(0)
  netPaid            Float?
  taxCategory        String?
  withholdingNote    String?
  mushak66DocumentNo String?
  createdAt          DateTime  @default(now())
  supplier           Supplier? @relation(fields: [supplierId], references: [id])

  @@index([branchId, createdAt])
  @@index([branchId, supplierId])
}

model ReceiptVoucher {
  id         Int       @id @default(autoincrement())
  branchId   Int
  customerId Int?
  amount     Float
  method     String
  note       String?
  createdAt  DateTime  @default(now())
  customer   Customer? @relation(fields: [customerId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entity    String
  entityId  Int?
  payload   Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Asset {
