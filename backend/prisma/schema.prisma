  category                String?
  purchaseDate            DateTime
  inServiceDate           DateTime
  cost                    Float
  salvageValue            Float     @default(0)
  usefulLifeMonths        Int
  depreciationMethod      String    @default("STRAIGHT_LINE")
  accumulatedDepreciation Float     @default(0)
  lastDepreciationDate    DateTime?
  status                  String    @default("ACTIVE")
  disposedAt              DateTime?
  disposalValue           Float?
  notes                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  branch              Branch                   @relation(fields: [branchId], references: [id])
  depreciationEntries AssetDepreciationEntry[]

  @@unique([branchId, assetCode])
  @@index([branchId, status])
}

model AssetDepreciationEntry {
  id        Int      @id @default(autoincrement())
  branchId  Int
  assetId   Int
  periodKey String
  amount    Float
  runDate   DateTime
  journalId Int?
  createdAt DateTime @default(now())

  asset   Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  journal Journal? @relation(fields: [journalId], references: [id])

  @@unique([assetId, periodKey])
  @@index([branchId, periodKey])
