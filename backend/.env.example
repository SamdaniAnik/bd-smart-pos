# --- Required ---
DATABASE_URL="mysql://root:@localhost:3306/bd_pos"
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change_me_to_a_secure_random_value"

# --- Server ---
NODE_ENV=development
PORT=5001
TRUST_PROXY=loopback
# Behind Railway/Render/nginx use 1 (or true — normalized to 1)

# --- Logging ---
# Levels: trace | debug | info | warn | error | fatal
# Defaults: debug in development, info in production
LOG_LEVEL=

# --- Auth ---
JWT_EXPIRES_IN=24h

# --- CORS ---
# Comma-separated list. Leave empty in dev (open). REQUIRED in production
# (an empty list in prod denies all browser origins for safety).
# Example: ALLOWED_ORIGINS=https://pos.example.com,https://staging.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Rate limiting ---
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_BOOTSTRAP_WINDOW_MS=3600000
RATE_LIMIT_BOOTSTRAP_MAX=5
# Global per-IP ceiling across all /api routes. Keep generous so a busy store
# behind one NAT isn't throttled; tighten if the API is internet-facing.
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=5000
# Strict ceiling for unauthenticated loyalty OTP requests (SMS cost / OTP bombing).
RATE_LIMIT_OTP_WINDOW_MS=900000
RATE_LIMIT_OTP_MAX=20

# --- Manager overrides ---
# PIN required to authorize sensitive overrides (e.g. dispensing expired stock).
# MUST be changed from the default and set to a strong value in production.
MANAGER_APPROVAL_PIN=

# --- Bootstrap (initial seed) ---
# Required in production. If unset in prod, /api/bootstrap/seed is disabled (503).
# Pass via header `X-Bootstrap-Token: <value>` or body `{ "seedToken": "<value>" }`.
BOOTSTRAP_SEED_TOKEN=

# --- Reports / receipt branding ---
REPORT_STORE_NAME="BD Smart POS"
REPORT_STORE_ADDRESS="Dhaka, Bangladesh"
REPORT_STORE_PHONE=""
REPORT_FOOTER_TEXT="Generated by BD Smart POS"

# --- Purchase payment schedule automation ---
# Required for /api/purchases/payment-schedule/automation/cron
PURCHASE_SCHEDULE_AUTOMATION_TOKEN=

# --- SMS gateway (retention + baki reminders) ---
# SMS_PROVIDER=log | bulksmsbd | ssl_wireless
SMS_PROVIDER=log
SMS_API_KEY=
SMS_SENDER_ID=
SMS_API_TOKEN=
SMS_SID=
# Bounded parallel sends for bulk SMS (1-20)
SMS_SEND_CONCURRENCY=5
# Salt for hashing loyalty OTPs at rest. REQUIRED in production (>=16 random chars).
# Falls back to JWT_SECRET in development when unset.
LOYALTY_OTP_SALT=

# --- MFS live payment verification ---
# MFS_PROVIDER=log (default) | bkash | nagad | rocket | upay
# Per-method override: MFS_BKASH_PROVIDER=bkash, MFS_NAGAD_PROVIDER=nagad,
#                      MFS_ROCKET_PROVIDER=rocket, MFS_UPAY_PROVIDER=upay
MFS_PROVIDER=log
MFS_BKASH_PROVIDER=
MFS_NAGAD_PROVIDER=
MFS_ROCKET_PROVIDER=
MFS_UPAY_PROVIDER=
# Redirect users back to this URL after an async MFS callback (optional)
MFS_CALLBACK_REDIRECT_URL=
# Optional shared secret for the public MFS callback endpoint. When set, callers
# must send a matching `X-Callback-Secret` header (or ?secret= for redirects).
# Defense in depth — the payment is still re-verified against the provider.
MFS_CALLBACK_SECRET=
BKASH_MERCHANT_NUMBER=
BKASH_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_CALLBACK_URL=http://localhost:5173
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_APP_ENV=sandbox
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0/api/dfs/
NAGAD_MERCHANT_PRIVATE_KEY=
NAGAD_PG_PUBLIC_KEY=
NAGAD_CALLBACK_URL=http://localhost:5173
NAGAD_CLIENT_IP=127.0.0.1
NAGAD_CURRENCY_CODE=050
# Rocket / Upay — merchant wallet for Bangla QR on customer display (log mode works without API keys).
# For live create/verify/refund set the merchant REST gateway below (HMAC-signed when *_API_SECRET set):
ROCKET_MERCHANT_NUMBER=
ROCKET_BASE_URL=
ROCKET_API_KEY=
ROCKET_API_SECRET=
ROCKET_MERCHANT_ID=
# ROCKET_CREATE_PATH=/payment/create  ROCKET_VERIFY_PATH=/payment/verify  ROCKET_REFUND_PATH=/payment/refund
ROCKET_CALLBACK_URL=
UPAY_MERCHANT_NUMBER=
UPAY_BASE_URL=
UPAY_API_KEY=
UPAY_API_SECRET=
UPAY_MERCHANT_ID=
UPAY_CALLBACK_URL=

# --- SaaS subscription billing ---
# SAAS_BILLING_PROVIDER=log (simulated upgrade) | bkash (live checkout via tokenized bKash)
SAAS_BILLING_PROVIDER=log

# --- EFD / NBR fiscal device (SDC) ---
# EFD_PROVIDER=log (simulated) | genex
EFD_PROVIDER=log
EFD_GENEX_URL=
EFD_GENEX_API_KEY=
EFD_DEVICE_ID=
EFD_MERCHANT_WALLET=
# Mushak 9.1 monthly VAT return — NBR iVAS / authorized ERP endpoint (case-by-case from NBR)
# EFD_MUSHAK91_PROVIDER=log (export-only) | ivas | erp
EFD_MUSHAK91_PROVIDER=log
EFD_MUSHAK91_URL=
EFD_MUSHAK91_API_KEY=
# Background EFD fiscalization retry sweeper (re-submits sales with no fiscal invoice)
EFD_RETRY_ENABLED=true
EFD_RETRY_INTERVAL_MS=300000
EFD_RETRY_MAX_ATTEMPTS=6
EFD_RETRY_LOOKBACK_DAYS=3
EFD_RETRY_BATCH_SIZE=20

# --- Top-up / utility bill aggregator ---
# TOPUP_PROVIDER=log (simulated) | aggregator (live distributor REST API)
TOPUP_PROVIDER=log
TOPUP_API_URL=
TOPUP_API_KEY=
# Optional path overrides on TOPUP_API_URL for the distributor adapter
TOPUP_PAY_PATH=
TOPUP_INQUIRY_PATH=/inquiry
TOPUP_REVERSE_PATH=/reverse

# --- Courier adapters ---
# COURIER_PROVIDER=log | manual | pathao | steadfast | redx | paperfly
COURIER_PROVIDER=log
# Pathao (branch courierApiKey = client_id, courierStoreId = store_id)
PATHAO_ENV=production
PATHAO_BASE_URL=https://api-hermes.pathao.com
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
PATHAO_STORE_ID=
PATHAO_DELIVERY_TYPE=48
PATHAO_ITEM_TYPE=2
PATHAO_ITEM_WEIGHT=0.5
# Steadfast
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
# RedX (branch courierApiKey = JWT token, courierStoreId = pickup_store_id)
REDX_BASE_URL=https://openapi.redx.com.bd/v1.0.0-beta
REDX_API_TOKEN=
REDX_PICKUP_STORE_ID=
REDX_DELIVERY_AREA_ID=1
REDX_DELIVERY_AREA_NAME=Dhaka
REDX_PARCEL_WEIGHT_GRAM=500
# Paperfly (branch courierApiKey = paperflykey)
PAPERFLY_API_KEY=
PAPERFLY_ORDER_URL=https://api.paperfly.com.bd/merchant/api/service/new_order.php
PAPERFLY_DEFAULT_DISTRICT=Dhaka
PAPERFLY_DEFAULT_THANA=Dhaka
PAPERFLY_PRODUCT_SIZE=standard
PAPERFLY_DELIVERY_OPTION=regular
PAPERFLY_MAX_WEIGHT_KG=1

# --- Local ESC/POS print bridge (optional, run: npm run print-bridge) ---
# PRINT_BRIDGE_PORT=9100
# PRINTER_DEVICE=   # e.g. /dev/usb/lp0 or COM3 — when set, raw bytes are written here

# --- Owner digest cron (daily SMS to store owner) ---
# OWNER_DIGEST_AUTOMATION_TOKEN=replace-with-a-long-random-secret
# POST /api/reports/owner-digest/cron?hour=21  (header x-automation-token)
